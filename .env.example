# .env.example
# Bu dosya bir şablondur. Gerçek değerleri .env dosyasına yazın.

# Uygulama Ayarları
DEBUG_MODE=True
CAMERA_ID=0  # Laptop'un kendi kamerası için 0, harici kamera için 1 veya 2

# LLM Ayarları
OPENAI_API_KEY=sk-ornek-api-anahtariniz-buraya-gelecek

# Skorlama Ayarları (İsteğe Bağlı - İleride weights.yaml'a da alınabilir)
FPS_TARGET=5
WINDOW_SIZE_SEC=5